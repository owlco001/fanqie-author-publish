{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/fanqie-author-publish/input.schema.json",
  "title": "fanqie-author-publish input schema",
  "description": "Schema for single-chapter and batch chapter inputs used by the fanqie-author-publish skill.",
  "oneOf": [
    {
      "$ref": "#/$defs/singleChapterInput"
    },
    {
      "$ref": "#/$defs/batchChapterInput"
    }
  ],
  "$defs": {
    "action": {
      "type": "string",
      "enum": [
        "prepare_draft",
        "review",
        "publish",
        "reconcile"
      ]
    },
    "linuxPath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^/.*"
    },
    "nonEmptyText": {
      "type": "string",
      "minLength": 1
    },
    "optionalText": {
      "type": "string"
    },
    "publishTime": {
      "type": "string",
      "description": "Optional publish time. Leave empty when not scheduling.",
      "default": ""
    },
    "singleChapterInput": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "book_name",
        "chapter_title",
        "chapter_body",
        "action"
      ],
      "properties": {
        "book_name": {
          "$ref": "#/$defs/nonEmptyText"
        },
        "chapter_title": {
          "$ref": "#/$defs/nonEmptyText"
        },
        "chapter_body": {
          "$ref": "#/$defs/nonEmptyText"
        },
        "action": {
          "$ref": "#/$defs/action"
        },
        "publish_time": {
          "$ref": "#/$defs/publishTime"
        },
        "source_file": {
          "oneOf": [
            {
              "$ref": "#/$defs/linuxPath"
            },
            {
              "type": "string",
              "maxLength": 0
            }
          ],
          "default": ""
        },
        "notes": {
          "$ref": "#/$defs/optionalText",
          "default": ""
        }
      }
    },
    "batchChapter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "chapter_title",
        "chapter_body"
      ],
      "properties": {
        "chapter_title": {
          "$ref": "#/$defs/nonEmptyText"
        },
        "chapter_body": {
          "$ref": "#/$defs/nonEmptyText"
        },
        "action": {
          "$ref": "#/$defs/action"
        },
        "publish_time": {
          "$ref": "#/$defs/publishTime",
          "default": ""
        },
        "source_file": {
          "oneOf": [
            {
              "$ref": "#/$defs/linuxPath"
            },
            {
              "type": "string",
              "maxLength": 0
            }
          ],
          "default": ""
        },
        "notes": {
          "$ref": "#/$defs/optionalText",
          "default": ""
        }
      }
    },
    "batchChapterInput": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "book_name",
        "default_action",
        "chapters"
      ],
      "properties": {
        "book_name": {
          "$ref": "#/$defs/nonEmptyText"
        },
        "default_action": {
          "$ref": "#/$defs/action"
        },
        "chapters": {
          "type": "array",
          "minItems": 1,
          "maxItems": 5,
          "items": {
            "$ref": "#/$defs/batchChapter"
          }
        }
      }
    }
  }
}

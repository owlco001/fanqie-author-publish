{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/qimao-author-publish/input.schema.json",
  "title": "qimao-author-publish input schema",
  "oneOf": [
    { "$ref": "#/$defs/singleChapterInput" },
    { "$ref": "#/$defs/batchChapterInput" }
  ],
  "$defs": {
    "action": {
      "type": "string",
      "enum": ["prepare_draft", "review", "publish", "reconcile"]
    },
    "singleChapterInput": {
      "type": "object",
      "additionalProperties": false,
      "required": ["book_name", "chapter_title", "chapter_body", "action"],
      "properties": {
        "book_name": { "type": "string", "minLength": 1 },
        "chapter_title": { "type": "string", "minLength": 1 },
        "chapter_body": { "type": "string", "minLength": 1 },
        "action": { "$ref": "#/$defs/action" },
        "publish_time": { "type": "string", "default": "" },
        "source_file": { "type": "string", "default": "" },
        "notes": { "type": "string", "default": "" }
      }
    },
    "batchChapterInput": {
      "type": "object",
      "additionalProperties": false,
      "required": ["book_name", "default_action", "chapters"],
      "properties": {
        "book_name": { "type": "string", "minLength": 1 },
        "default_action": { "$ref": "#/$defs/action" },
        "chapters": {
          "type": "array",
          "minItems": 1,
          "maxItems": 5,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["chapter_title", "chapter_body"],
            "properties": {
              "chapter_title": { "type": "string", "minLength": 1 },
              "chapter_body": { "type": "string", "minLength": 1 },
              "action": { "$ref": "#/$defs/action" },
              "publish_time": { "type": "string", "default": "" },
              "source_file": { "type": "string", "default": "" },
              "notes": { "type": "string", "default": "" }
            }
          }
        }
      }
    }
  }
}
